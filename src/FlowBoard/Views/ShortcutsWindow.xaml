<ui:FluentWindow x:Class="FlowBoard.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Keyboard shortcuts"
        Width="460" Height="520"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/FlowBoard.ico"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Keyboard shortcuts" />

        <ScrollViewer Grid.Row="1" Padding="20,4,20,16" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="Shortcuts">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource LaneBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardStrokeBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Keys}"
                                           FontFamily="{StaticResource UtilityFont}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Action}"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource BodyFont}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
