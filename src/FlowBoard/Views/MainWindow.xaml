<ui:FluentWindow x:Class="FlowBoard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:FlowBoard.Views"
        xmlns:dd="clr-namespace:FlowBoard.Views.DragDrop"
        xmlns:vm="clr-namespace:FlowBoard.ViewModels"
        xmlns:domain="clr-namespace:FlowBoard.Domain"
        xmlns:services="clr-namespace:FlowBoard.Services"
        Title="FlowBoard"
        Width="1360" Height="820"
        MinWidth="1024" MinHeight="640"
        Icon="pack://application:,,,/Assets/FlowBoard.ico"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        dd:Drag.Host="True">

    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexBrush" />
        <local:BoardIsSelectedConverter x:Key="IsSelected" />
        <local:EqualityToVisibilityConverter x:Key="IsSelectedVisibility" />
        <local:AccentWashConverter x:Key="AccentWash" />
        <local:AccentArgsConverter x:Key="AccentArgs" />
        <local:EnumEqualsConverter x:Key="EnumEquals" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:InverseBooleanToVisibilityConverter x:Key="NotBoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="FlowBoard">
            <ui:TitleBar.Header>
                <Menu Margin="52,0,0,0" Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="_File">
                        <MenuItem Header="_Export workspace…" InputGestureText="Ctrl+E"
                                  Command="{Binding ExportCommand}" />
                        <MenuItem Header="_Import workspace…" Command="{Binding ImportCommand}" />
                        <Separator />
                        <MenuItem Header="_Archive…" InputGestureText="Ctrl+Shift+A"
                                  Command="{Binding ShowArchiveCommand}" />
                        <MenuItem Header="_Labels…" Command="{Binding ShowLabelsCommand}" />
                    </MenuItem>
                    <MenuItem Header="_View">
                        <!-- IsCheckable is what actually draws the tick. Without it, IsChecked
                             is set and silently invisible — which is why these read as dead
                             toggles with no way to tell their state. -->
                        <MenuItem Header="_Collapse sidebar" InputGestureText="Ctrl+B"
                                  IsCheckable="True"
                                  Command="{Binding ToggleSidebarCommand}"
                                  IsChecked="{Binding Settings.SidebarCollapsed, Mode=OneWay}" />
                        <MenuItem Header="Card _ageing" ToolTip="Fade cards that haven't been touched in a while"
                                  IsCheckable="True"
                                  Command="{Binding ToggleAgingCommand}"
                                  IsChecked="{Binding Settings.CardAgingEnabled, Mode=OneWay}" />
                        <Separator />
                        <MenuItem Header="Theme: follow _Windows" IsCheckable="True"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static services:ThemePreference.System}"
                                  IsChecked="{Binding Settings.Theme, Mode=OneWay,
                                              Converter={StaticResource EnumEquals},
                                              ConverterParameter={x:Static services:ThemePreference.System}}" />
                        <MenuItem Header="Theme: _light" IsCheckable="True"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static services:ThemePreference.Light}"
                                  IsChecked="{Binding Settings.Theme, Mode=OneWay,
                                              Converter={StaticResource EnumEquals},
                                              ConverterParameter={x:Static services:ThemePreference.Light}}" />
                        <MenuItem Header="Theme: _dark" IsCheckable="True"
                                  Command="{Binding SetThemeCommand}"
                                  CommandParameter="{x:Static services:ThemePreference.Dark}"
                                  IsChecked="{Binding Settings.Theme, Mode=OneWay,
                                              Converter={StaticResource EnumEquals},
                                              ConverterParameter={x:Static services:ThemePreference.Dark}}" />
                    </MenuItem>
                    <MenuItem Header="_Help">
                        <MenuItem Header="_Keyboard shortcuts" InputGestureText="?"
                                  Command="{Binding ShowShortcutsCommand}" />
                    </MenuItem>
                </Menu>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Sidebar: workspaces, and the cross-workspace drop target. -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                Width="216" Padding="12,8,12,12"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource LaneStrokeBrush}"
                Visibility="{Binding Settings.SidebarCollapsed, Converter={StaticResource NotBoolToVisibility}}">
            <DockPanel>
                <!-- Labels and Archive live at the bottom, away from the workspaces:
                     they're destinations, not peers of them. -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Margin="0,8,0,8" Background="{DynamicResource LaneStrokeBrush}" />
                    <ui:Button Content="Labels"
                               Icon="{ui:SymbolIcon Tag24}"
                               Appearance="Transparent"
                               HorizontalContentAlignment="Left"
                               HorizontalAlignment="Stretch"
                               Padding="10,7"
                               Command="{Binding ShowLabelsCommand}" />

                    <!-- Bigger than the rest, and a drop target: a card dragged here is
                         archived. Being a drop target is the reason for the size — you have
                         to be able to hit it while holding a card. -->
                    <Border x:Name="ArchiveDropZone"
                            dd:Drag.ArchiveZone="True"
                            Margin="0,4,0,0"
                            CornerRadius="6"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="Transparent">
                        <ui:Button Content="Archive"
                                   Icon="{ui:SymbolIcon Archive24}"
                                   Appearance="Transparent"
                                   HorizontalContentAlignment="Left"
                                   HorizontalAlignment="Stretch"
                                   Padding="10,12"
                                   FontSize="{StaticResource FontSizeBody}"
                                   ToolTip="Open the archive — or drag a card here to archive it"
                                   Command="{Binding ShowArchiveCommand}" />
                    </Border>
                </StackPanel>

                <StackPanel>
                <Grid Margin="4,4,0,8">
                    <TextBlock Text="WORKSPACES"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource UtilityFont}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextTertiaryBrush}" />
                    <ui:Button HorizontalAlignment="Right" Appearance="Transparent"
                               Padding="4,0" ToolTip="New workspace"
                               Icon="{ui:SymbolIcon Add24}"
                               Command="{Binding AddWorkspaceCommand}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Model.Workspaces}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type domain:Workspace}">
                            <Grid Margin="0,1"
                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename"
                                                  Command="{Binding PlacementTarget.Tag.BeginRenameWorkspaceCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="Delete workspace"
                                                  Command="{Binding PlacementTarget.Tag.DeleteWorkspaceCommand,
                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext,
                                                                     RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <ui:Button Content="{Binding Name}"
                                           Appearance="Transparent"
                                           HorizontalContentAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           dd:Drag.WorkspaceZone="True"
                                           Command="{Binding DataContext.SelectWorkspaceCommand,
                                                     RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding}">
                                    <ui:Button.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.BeginRenameWorkspaceCommand,
                                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}" />
                                    </ui:Button.InputBindings>
                                    <ui:Button.Visibility>
                                        <MultiBinding Converter="{StaticResource IsSelectedVisibility}"
                                                      ConverterParameter="invert">
                                            <Binding />
                                            <Binding Path="DataContext.RenamingWorkspace"
                                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </ui:Button.Visibility>
                                </ui:Button>

                                <ui:TextBox local:InlineEdit.Target="Workspace"
                                            Text="{Binding DataContext.WorkspaceRenameText,
                                                   RelativeSource={RelativeSource AncestorType=Window},
                                                   UpdateSourceTrigger=PropertyChanged}">
                                    <ui:TextBox.Visibility>
                                        <MultiBinding Converter="{StaticResource IsSelectedVisibility}">
                                            <Binding />
                                            <Binding Path="DataContext.RenamingWorkspace"
                                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </ui:TextBox.Visibility>
                                </ui:TextBox>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Toolbar: title, search, filters, undo -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="16,4,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="{StaticResource FontSizeTitle}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Text="{Binding ActiveWorkspace.Name}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:TextBox x:Name="SearchBox" Width="200" Margin="0,0,12,0"
                            PlaceholderText="Search  (F)"
                            Text="{Binding Filter.Text, UpdateSourceTrigger=PropertyChanged, Delay=120}" />

                <!-- Labelled, because an unlabelled combo showing "Manual" tells you what it
                     says, not what it does. -->
                <TextBlock Text="Filter" VerticalAlignment="Center" Margin="0,0,6,0"
                           Style="{StaticResource MetaText}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ComboBox Width="124" Margin="0,0,12,0"
                          ItemsSource="{Binding Model.Labels}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          SelectedValue="{Binding Filter.LabelId}"
                          ToolTip="Show only cards with this label" />

                <TextBlock Text="Sort" VerticalAlignment="Center" Margin="0,0,6,0"
                           Style="{StaticResource MetaText}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <ComboBox Width="118" Margin="0,0,8,0"
                          ItemsSource="{Binding SortModes}"
                          SelectedItem="{Binding Sort}"
                          ToolTip="Sort is display-only — your manual order is kept. Dragging cards is disabled unless this is Manual." />

                <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                           ToolTip="Clear filters"
                           Visibility="{Binding Filter.IsActive, Converter={StaticResource BoolToVisibility}}"
                           Command="{Binding Filter.ClearCommand}" />

                <ui:Button Icon="{ui:SymbolIcon ArrowUndo24}" Appearance="Transparent"
                           ToolTip="{Binding Undo.UndoLabel}"
                           IsEnabled="{Binding Undo.CanUndo}"
                           Command="{Binding UndoLastCommand}" />
                <ui:Button Icon="{ui:SymbolIcon ArrowRedo24}" Appearance="Transparent"
                           ToolTip="{Binding Undo.RedoLabel}"
                           IsEnabled="{Binding Undo.CanRedo}"
                           Command="{Binding RedoLastCommand}" />
            </StackPanel>
        </Grid>

        <!-- Board surface: each board is a lane, laid out left to right. -->
        <ScrollViewer Grid.Row="2" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16"
                      dd:Drag.AutoScroll="Horizontal">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding ActiveWorkspace.Boards}"
                              dd:Drag.LaneZone="True">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type domain:Board}">
                            <!-- Two borders, deliberately. The outer one keeps the theme's
                                 DynamicResource background; the inner lays the board's
                                 accent over it as a translucent wash. Compositing the two at
                                 render time is what lets a recoloured lane still follow a
                                 light/dark switch — a single pre-blended colour would be
                                 computed against one theme and then rot. -->
                            <Border Width="{StaticResource LaneWidth}"
                                    dd:Drag.LaneRoot="True"
                                    Margin="0,0,12,0"
                                    CornerRadius="{StaticResource LaneRadius}"
                                    Background="{DynamicResource LaneBackgroundBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{Binding Accent, Converter={StaticResource AccentWash}, ConverterParameter=90}">
                              <Border CornerRadius="{StaticResource LaneRadius}"
                                      Padding="{StaticResource LanePadding}"
                                      Background="{Binding Accent, Converter={StaticResource AccentWash}, ConverterParameter=26}">
                                <DockPanel>
                                    <!-- Lane header: accent, name, count. Also the drag
                                         handle for reordering boards. -->
                                    <Grid DockPanel.Dock="Top" Margin="6,2,4,10"
                                          Background="Transparent"
                                          Cursor="SizeAll"
                                          dd:Drag.LaneSource="True"
                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                          Command="{Binding DataContext.BeginRenameCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>

                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename"
                                                          Command="{Binding PlacementTarget.Tag.BeginRenameCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="Colour"
                                                          ItemsSource="{Binding PlacementTarget.Tag.Accents,
                                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="12" Height="12" CornerRadius="3"
                                                                        Margin="0,0,8,0"
                                                                        Background="{Binding Converter={StaticResource HexBrush}}" />
                                                                <TextBlock Text="{Binding}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </MenuItem.ItemTemplate>
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Command"
                                                                    Value="{Binding PlacementTarget.Tag.SetBoardAccentCommand,
                                                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <Setter Property="CommandParameter">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource AccentArgs}">
                                                                        <Binding Path="PlacementTarget.DataContext"
                                                                                 RelativeSource="{RelativeSource AncestorType=ContextMenu}" />
                                                                        <Binding />
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="Archive board"
                                                          Command="{Binding PlacementTarget.Tag.ArchiveBoardCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>

                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="3" Height="14" CornerRadius="1.5"
                                                    Margin="0,0,8,0"
                                                    Background="{Binding Accent, Converter={StaticResource HexBrush}}" />
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource LaneTitleText}">
                                                <TextBlock.Visibility>
                                                    <MultiBinding Converter="{StaticResource IsSelectedVisibility}"
                                                                  ConverterParameter="invert">
                                                        <Binding />
                                                        <Binding Path="DataContext.RenamingBoard"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Visibility>
                                            </TextBlock>
                                        </StackPanel>

                                        <ui:TextBox local:InlineEdit.Target="Board"
                                                    Margin="11,0,28,0"
                                                    Text="{Binding DataContext.RenameText,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           UpdateSourceTrigger=PropertyChanged}">
                                            <ui:TextBox.Visibility>
                                                <MultiBinding Converter="{StaticResource IsSelectedVisibility}">
                                                    <Binding />
                                                    <Binding Path="DataContext.RenamingBoard"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </ui:TextBox.Visibility>
                                        </ui:TextBox>

                                        <TextBlock Text="{Binding Cards.Count}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource MetaText}"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                                    </Grid>

                                    <!-- Quick add: inline box, or the button that opens it -->
                                    <Grid DockPanel.Dock="Bottom">
                                        <ui:Button Content="+ Add card"
                                                   Appearance="Transparent"
                                                   HorizontalAlignment="Stretch"
                                                   HorizontalContentAlignment="Left"
                                                   Command="{Binding DataContext.BeginQuickAddCommand,
                                                             RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}">
                                            <ui:Button.Visibility>
                                                <MultiBinding Converter="{StaticResource IsSelectedVisibility}"
                                                              ConverterParameter="invert">
                                                    <Binding />
                                                    <Binding Path="DataContext.QuickAddBoard"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </ui:Button.Visibility>
                                        </ui:Button>

                                        <ui:TextBox local:QuickAdd.FocusWhenVisible="True"
                                                    PlaceholderText="Card title, Enter to add"
                                                    AcceptsReturn="False"
                                                    Text="{Binding DataContext.QuickAddText,
                                                           RelativeSource={RelativeSource AncestorType=Window},
                                                           UpdateSourceTrigger=PropertyChanged}">
                                            <ui:TextBox.Visibility>
                                                <MultiBinding Converter="{StaticResource IsSelectedVisibility}">
                                                    <Binding />
                                                    <Binding Path="DataContext.QuickAddBoard"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </ui:TextBox.Visibility>
                                        </ui:TextBox>
                                    </Grid>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Padding="0,0,4,0"
                                                  dd:Drag.AutoScroll="Vertical">
                                        <!-- MinHeight keeps an empty lane a valid drop
                                             target; a zero-height zone can't be hit. -->
                                        <ItemsControl ItemsSource="{Binding Cards}"
                                                      ItemTemplate="{StaticResource CardFaceTemplate}"
                                                      MinHeight="60"
                                                      Background="Transparent"
                                                      dd:Drag.CardZone="True" />
                                    </ScrollViewer>
                                </DockPanel>
                              </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:Button Content="+ Add board" Appearance="Transparent"
                           VerticalAlignment="Top" Height="38"
                           Command="{Binding AddBoardCommand}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
