<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        FlowBoard dark tokens. Every colour in the app resolves through a key defined here
        and in Tokens.Light.xaml — the two files must always carry an identical key set, so
        a theme swap is a dictionary swap and nothing else.

        The neutral ramp is cool ink (blue-leaning greys), not the usual neutral grey: the
        board accents are user data and can be any hue, so the chrome has to sit back and
        stay out of their way.
    -->

    <!-- Surfaces. Mica shows through the window, so the canvas stays unpainted. -->
    <Color x:Key="LaneBackgroundColor">#161A21</Color>
    <Color x:Key="LaneStrokeColor">#242A34</Color>
    <Color x:Key="CardBackgroundColor">#1E232C</Color>
    <Color x:Key="CardHoverColor">#242A35</Color>
    <Color x:Key="CardStrokeColor">#2C333F</Color>
    <Color x:Key="CardSelectedStrokeColor">#4C8DFF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E8EBF0</Color>
    <Color x:Key="TextSecondaryColor">#98A2B3</Color>
    <Color x:Key="TextTertiaryColor">#6B7688</Color>

    <!--
        Priority ramp: cool -> hot. Amber is deliberately absent so the strip can never be
        confused with the due-soon pill.
    -->
    <Color x:Key="PriorityLowColor">#6E8BA6</Color>
    <Color x:Key="PriorityMediumColor">#5D6BD8</Color>
    <Color x:Key="PriorityHighColor">#A855C9</Color>
    <Color x:Key="PriorityCriticalColor">#D92D6B</Color>

    <!-- Due states -->
    <Color x:Key="DueSoonColor">#E8A33D</Color>
    <Color x:Key="DueOverdueColor">#E5484D</Color>

    <SolidColorBrush x:Key="LaneBackgroundBrush" Color="{StaticResource LaneBackgroundColor}" />
    <SolidColorBrush x:Key="LaneStrokeBrush" Color="{StaticResource LaneStrokeColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="CardStrokeBrush" Color="{StaticResource CardStrokeColor}" />
    <SolidColorBrush x:Key="CardSelectedStrokeBrush" Color="{StaticResource CardSelectedStrokeColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <SolidColorBrush x:Key="PriorityLowBrush" Color="{StaticResource PriorityLowColor}" />
    <SolidColorBrush x:Key="PriorityMediumBrush" Color="{StaticResource PriorityMediumColor}" />
    <SolidColorBrush x:Key="PriorityHighBrush" Color="{StaticResource PriorityHighColor}" />
    <SolidColorBrush x:Key="PriorityCriticalBrush" Color="{StaticResource PriorityCriticalColor}" />

    <SolidColorBrush x:Key="DueSoonBrush" Color="{StaticResource DueSoonColor}" />
    <SolidColorBrush x:Key="DueOverdueBrush" Color="{StaticResource DueOverdueColor}" />

    <!-- Card shadow: one soft, low shadow. Dark themes need less of it, not more. -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2"
                      Direction="270" Opacity="0.34" Color="#000000" />
    <DropShadowEffect x:Key="CardDragShadow" BlurRadius="28" ShadowDepth="8"
                      Direction="270" Opacity="0.52" Color="#000000" />

</ResourceDictionary>
