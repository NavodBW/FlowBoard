<Application x:Class="FlowBoard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Order matters: each dictionary can only StaticResource-resolve keys from
                 the ones merged before it. Fluent base, then our type scale, then the
                 templates that consume it. Tokens.Dark/Light are merged at runtime by
                 ThemeTokens, on top of all of this. -->
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Theme/Typography.xaml" />
                <ResourceDictionary Source="Views/Templates/CardFace.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
